// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id        String    @id @default(cuid())
  email     String    @unique
  firstName String?
  lastName  String?
  bio       String?
  avatarUrl String?
  location  String?
  timezone  String?
  verified  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  skills                  UserSkill[]
  learningGoals           LearningGoal[]
  matchesAsRequester      Match[]         @relation("requester")
  matchesAsCandidate      Match[]         @relation("candidate")
  sessionParticipants     SessionParticipant[]
  reputationScores        ReputationScore?
  contributionBalances    ContributionBalance?
  nexosWallets            NexosWallet?

  @@index([email])
  @@index([createdAt])
  @@map("profiles")
}

model UserSkill {
  id        String   @id @default(cuid())
  userId    String
  skill     String
  level     String   @default("beginner") // beginner, intermediate, advanced, expert
  yearsOfExperience Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skill])
  @@index([userId])
  @@map("user_skills")
}

model Skill {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("skills")
}

model LearningGoal {
  id        String   @id @default(cuid())
  userId    String
  title     String
  description String?
  skillToLearn String
  targetLevel String   @default("intermediate")
  status    String   @default("active") // active, completed, abandoned
  priority  String   @default("medium") // low, medium, high
  dueDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([skillToLearn])
  @@map("learning_goals")
}

model Match {
  id        String   @id @default(cuid())
  requesterId String
  candidateId String
  status    String   @default("pending") // pending, accepted, declined, cancelled, expired
  reason    String?
  compatibilityScore Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime?

  requester Profile @relation("requester", fields: [requesterId], references: [id], onDelete: Cascade)
  candidate Profile @relation("candidate", fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([requesterId, candidateId])
  @@index([requesterId])
  @@index([candidateId])
  @@index([status])
  @@index([createdAt])
  @@map("matches")
}

model ExchangeSession {
  id        String   @id @default(cuid())
  title     String
  description String?
  status    String   @default("scheduled") // scheduled, in_progress, completed, cancelled, no_show
  scheduledAt DateTime
  durationMinutes Int   @default(60)
  location  String?
  verificationStatus String @default("pending") // pending, verified, no_show
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants SessionParticipant[]
  reviews      SessionReview[]

  @@index([status])
  @@index([scheduledAt])
  @@map("exchange_sessions")
}

model SessionParticipant {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  role      String   @default("participant") // host, participant, learner
  confirmationStatus String @default("pending") // pending, confirmed, declined, no_show
  confirmationToken String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session ExchangeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
  @@map("session_participants")
}

model SessionReview {
  id        String   @id @default(cuid())
  sessionId String
  reviewerId String
  rating    Int      @default(5) // 1-5
  comment   String?
  moderation String? @default(null) // null, approved, flagged, rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session ExchangeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, reviewerId])
  @@index([sessionId])
  @@index([moderation])
  @@map("session_reviews")
}

model ReputationScore {
  id        String   @id @default(cuid())
  userId    String   @unique
  score     Float    @default(0.0)
  level     String   @default("novice") // novice, contributor, expert, leader
  reviewCount Int     @default(0)
  positiveReviews Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([score])
  @@map("reputation_scores")
}

model ContributionBalance {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Float    @default(0.0)
  lifetime  Float    @default(0.0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions ContributionTransaction[]

  @@index([userId])
  @@map("contribution_balances")
}

model ContributionTransaction {
  id        String   @id @default(cuid())
  balanceId String
  amount    Float
  type      String   // session_complete, review_bonus, manual_adjustment, redemption
  description String?
  reference String?
  createdAt DateTime @default(now())

  balance ContributionBalance @relation(fields: [balanceId], references: [id], onDelete: Cascade)

  @@index([balanceId])
  @@index([type])
  @@map("contribution_transactions")
}

model NexosWallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Float    @default(0.0)
  lifetime  Float    @default(0.0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions NexosTransaction[]

  @@index([userId])
  @@map("nexos_wallets")
}

model NexosTransaction {
  id        String   @id @default(cuid())
  walletId  String
  amount    Float
  type      String   // mint, transfer, spend, reward, adjustment
  fromWalletId String?
  toWalletId String?
  description String?
  reference String?
  status    String   @default("completed") // pending, completed, failed
  createdAt DateTime @default(now())

  wallet NexosTransaction @relation("wallet", fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([type])
  @@index([status])
  @@map("nexos_transactions")
}

// Fix the self-referencing relation
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String
  resourceId String?
  changes   String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@map("audit_logs")
}
